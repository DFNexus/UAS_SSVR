{
	"info": {
		"name": "UAS-SSVR Simple LMS API - INSTRUCTOR",
		"description": "Koleksi endpoint untuk menguji Simple LMS API dari sisi Instruktur (Pembuat Materi).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login (Instructor)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"token\", jsonData.access);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"instructor1\",\n    \"password\": \"instructor123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					}
				},
				{
					"name": "Get Profile (Me)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/api/auth/me",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"me"
							]
						}
					}
				}
			]
		},
		{
			"name": "Courses & Curriculum",
			"item": [
				{
					"name": "Create Course",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Advanced Rust Programming\",\n    \"description\": \"Learn Rust concepts.\",\n    \"category_id\": 1,\n    \"level\": \"advanced\",\n    \"status\": \"published\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/courses/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"courses",
								""
							]
						}
					}
				},
				{
					"name": "Create Section",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Chapter 1: Ownership\",\n    \"order\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/courses/1/sections",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"courses",
								"1",
								"sections"
							]
						}
					}
				},
				{
					"name": "Create Lesson",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Borrow Checker Basics\",\n    \"content\": \"Explanation of borrow checker rules...\",\n    \"order\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/sections/1/lessons",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"sections",
								"1",
								"lessons"
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000"
		},
		{
			"key": "token",
			"value": "PASTE_ACCESS_TOKEN_HERE"
		}
	]
}
